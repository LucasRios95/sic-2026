# =============================================================================
#  Sistema Fiscal-Financeiro — variáveis de ambiente
#  Copie para .env e ajuste os valores. Nunca commite .env.
# =============================================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3333
LOG_LEVEL=debug

# --- Banco de dados (PostgreSQL 16+) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=sic_2026
DB_SCHEMA=public
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SYNCHRONIZE=false
DB_LOGGING=false

# --- Autenticação ---
JWT_SECRET=change-me-to-a-long-random-string-em-prod-use-cofre
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_COST=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION_MINUTES=15

# --- CORS (lista separada por vírgula) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- SEFAZ / TLS ---
# Caminho para o bundle PEM com a cadeia ICP-Brasil (raiz + intermediárias).
# Necessário em PRODUÇÃO; em HOMOLOGAÇÃO, deixar vazio aceita qualquer issuer
# (ambiente de teste isolado). Obtenha o bundle no portal do ITI ou em clientes
# Node de NF-e da comunidade (focus-nfe, node-sped-nfe).
# Exemplo: NFE_TLS_CA_BUNDLE=/app/certs/icp-brasil.pem
NFE_TLS_CA_BUNDLE=
