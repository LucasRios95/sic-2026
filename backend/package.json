{
  "name": "sic-2026-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema Fiscal-Financeiro — backend (NF-e modelo 55 direto SEFAZ + NFS-e via Focus NF-e). Substitui o legado Delphi/BDE/Paradox, preparado para a Reforma Tributária (IBS/CBS/IS).",
  "main": "dist/shared/infra/http/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/shared/infra/http/server.ts",
    "worker": "tsx watch --clear-screen=false src/shared/infra/queues/worker.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/shared/infra/http/server.js",
    "start:worker": "node dist/shared/infra/queues/worker.js",
    "typeorm": "tsx ./node_modules/typeorm/cli.js -d src/shared/infra/typeorm/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "seed": "tsx src/shared/infra/typeorm/seeds/run-seeds.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@react-pdf/renderer": "^4.1.6",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "bwip-js": "^4.5.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "fast-xml-parser": "^4.5.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "react": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3",
    "xml-crypto": "^6.0.0",
    "xmlbuilder2": "^3.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/node-forge": "^1.3.11",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.18",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import-helpers": "^1.3.1",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
